generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PruebaType {
  MAYORES_25
  MAYORES_40
  MAYORES_45
}

enum TipoPregunta {
  TEST
  ABIERTA
}

enum Dificultad {
  BASICO
  INTERMEDIO
  AVANZADO
}

enum FuentePregunta {
  OFICIAL
  GENERADA
}

enum TipoDocumento {
  EXAMEN_OFICIAL
  MODELO
  CONVOCATORIA_ANTERIOR
  ORIENTACIONES
  CRITERIOS_CORRECCION
  SOLUCIONARIO
}

enum DocumentoStatus {
  FOUND
  DOWNLOADED
  CATALOGUED
  REVIEWED
  PUBLISHED
  INTERACTIVE_READY
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum SesionEstado {
  INICIADA
  PAUSADA
  FINALIZADA
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  passwordHash     String
  nombre           String?
  pruebaType       PruebaType?
  comunidad        String?
  onboardingDone   Boolean     @default(false)
  role             UserRole    @default(USER)
  stripeCustomerId String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  fechaExamen      DateTime?
  
  // Perfil detalhado
  avatarUrl        String?
  phone            String?
  provincia        String?
  bio              String?     @db.Text
  pais             String      @default("España")

  subscription  Subscription?
  sesiones      Sesion[]
  respuestas    RespuestaUsuario[]
  tareasPlan    TareaPlan[]
  forumPosts    ForumPost[]
  forumComments ForumComment[]
  forumReports  ForumReport[]
  flashcards    Flashcard[]
  favoritos     Favorito[]

  @@map("users")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

model Materia {
  id          String       @id @default(cuid())
  nombre      String
  descripcion String?
  pruebaType  PruebaType[]
  fase        String
  orden       Int          @default(0)
  activa      Boolean      @default(true)
  createdAt   DateTime     @default(now())

  preguntas  Pregunta[]
  sesiones   Sesion[]
  tareasPlan TareaPlan[]
  forumPosts ForumPost[]
  flashcards Flashcard[]

  @@map("materias")
}

model Pregunta {
  id         String         @id @default(cuid())
  materiaId  String
  enunciado  String
  tipo       TipoPregunta   @default(TEST)
  dificultad Dificultad     @default(INTERMEDIO)
  fuente     FuentePregunta @default(OFICIAL)
  tema       String?
  anio       Int?
  comunidad  String?
  universidad String?
  activa     Boolean        @default(true)
  createdAt  DateTime       @default(now())

  materia    Materia            @relation(fields: [materiaId], references: [id])
  opciones   Opcion[]
  respuestas RespuestaUsuario[]
  flashcards Flashcard[]
  favoritos  Favorito[]

  @@map("preguntas")
}

model Opcion {
  id         String @id @default(cuid())
  preguntaId String
  texto      String
  esCorrecta Boolean @default(false)
  orden      Int     @default(0)

  pregunta   Pregunta           @relation(fields: [preguntaId], references: [id])
  respuestas RespuestaUsuario[]

  @@map("opciones")
}

model Sesion {
  id               String   @id @default(cuid())
  userId           String
  materiaId        String
  totalPreguntas   Int
  aciertos         Int      @default(0)
  completada       Boolean  @default(false)
  estado           SesionEstado @default(INICIADA)
  currentIndex     Int      @default(0)
  duracionSegundos Int?
  createdAt        DateTime @default(now())

  user       User               @relation(fields: [userId], references: [id])
  materia    Materia            @relation(fields: [materiaId], references: [id])
  respuestas RespuestaUsuario[]

  @@map("sesiones")
}

model RespuestaUsuario {
  id              String   @id @default(cuid())
  userId          String
  preguntaId      String
  sesionId        String
  opcionId        String?
  respuestaTexto  String?
  esCorrecta      Boolean
  feedbackIA      String?
  tiempoRespuesta Int?
  revisado        Boolean  @default(false)
  createdAt       DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  pregunta Pregunta @relation(fields: [preguntaId], references: [id])
  sesion   Sesion   @relation(fields: [sesionId], references: [id])
  opcion   Opcion?  @relation(fields: [opcionId], references: [id])

  @@map("respuestas_usuario")
}

model TareaPlan {
  id        String   @id @default(cuid())
  userId    String
  materiaId String
  diaSemana Int      // 0 (Lunes) a 6 (Domingo)
  completada Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  materia   Materia  @relation(fields: [materiaId], references: [id])

  @@map("tareas_plan")
}

model ForumPost {
  id                String   @id @default(cuid())
  userId            String
  materiaId         String?
  titulo            String
  contenido         String   @db.Text
  likesCount        Int      @default(0)
  isSolved          Boolean  @default(false)
  acceptedCommentId String?  @unique
  quotePostId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id])
  materia   Materia?       @relation(fields: [materiaId], references: [id])
  quotePost ForumPost?     @relation("QuotePost", fields: [quotePostId], references: [id])
  quotedBy  ForumPost[]    @relation("QuotePost")
  comments  ForumComment[] @relation("PostComments")
  reports   ForumReport[]

  @@map("forum_posts")
}

model ForumComment {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  contenido  String   @db.Text
  likesCount Int      @default(0)
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post ForumPost @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id])

  @@map("forum_comments")
}

model ForumReport {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  razon     String
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("forum_reports")
}

model Flashcard {
  id         String   @id @default(cuid())
  userId     String
  preguntaId String?
  materiaId  String?
  frente     String   @db.Text
  dorso      String   @db.Text
  estado     String   @default("pendiente")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pregunta Pregunta? @relation(fields: [preguntaId], references: [id])
  materia  Materia?  @relation(fields: [materiaId], references: [id])

  @@map("flashcards")
}

model ExamDocument {
  id            String          @id @default(cuid())
  title         String
  subject       String
  community     String
  university    String
  year          Int
  call          String?         // "ordinaria" | "extraordinaria" | null
  documentType  TipoDocumento
  sourceUrl     String          // URL oficial de origen
  sourceName    String          // nombre fuente oficial (ej: "UCM - Pruebas mayores 25")
  pdfUrl        String?         // URL directa al PDF si disponible
  isOfficial    Boolean         @default(true)
  isInteractive Boolean         @default(false)
  status        DocumentoStatus @default(FOUND)
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([community])
  @@index([university])
  @@index([subject])
  @@index([year])
  @@index([documentType])
  @@index([status])
  @@map("exam_documents")
}

model Favorito {
  id         String   @id @default(cuid())
  userId     String
  preguntaId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pregunta Pregunta @relation(fields: [preguntaId], references: [id])

  @@unique([userId, preguntaId])
  @@map("favoritos")
}
